{
  "name": "@statehub/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && wrangler pages dev",
    "deploy": "opennextjs-cloudflare build && rm -rf .open-next/server-functions/default/apps/web/.next/cache && wrangler deploy --keep-vars",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "gen:integration-key": "tsx scripts/gen-integration-key.ts",
    "gen:auth-secret": "tsx scripts/gen-auth-secret.ts",
    "add-user": "tsx scripts/add-user.ts"
  },
  "dependencies": {
    "@statehub/config": "workspace:*",
    "@statehub/db": "workspace:*",
    "@statehub/domain": "workspace:*",
    "@statehub/integrations": "workspace:*",
    "@statehub/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@opennextjs/cloudflare": "1.20.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.107.1"
  }
}
