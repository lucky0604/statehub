# StateHub Web — production environment template.
#
# This lists the env vars you must configure in your Cloudflare Pages
# project (dashboard → Settings → Environment variables). Do NOT check
# real values into the repo — set them via the Cloudflare dashboard or
# `wrangler pages secret put`.
#
# See docs/deploying.md for the full deploy walkthrough.

# REQUIRED — AES-256-GCM key for encrypting provider tokens at rest.
# Generate locally with:
#   pnpm --filter @statehub/web run gen:integration-key
# Then paste the base64 string into Cloudflare as a secret.
# WARNING: losing this key makes existing encrypted tokens unrecoverable.
STATEHUB_INTEGRATION_KEY=

# REQUIRED — canonical app URL. After your first deploy, set this to
# your https://<project>.pages.dev URL (or custom domain).
APP_URL=https://your-statehub.pages.dev

# Optional — AI provider keys. The AI PM degrades gracefully without
# them (returns "AI providers not configured" errors on /ask).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# GLM_API_KEY=

# Optional — auth mode. Default "disabled" = solo-dev (no auth).
# Multi-user auth lands in a later phase; do NOT deploy with
# AUTH_MODE=disabled to a public URL without Cloudflare Access (see
# docs/deploying.md §"Securing the deploy").
AUTH_MODE=disabled
