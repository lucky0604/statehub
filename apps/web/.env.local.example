# StateHub Web — local environment template.
#
# Copy this file to .env.local and fill in the values you need.
# .env.local is gitignored — never commit real secrets.

# P07D: AES-256-GCM key for encrypting provider tokens (PAT, API tokens)
# in integrations.config_json. Must be 32 bytes, base64-encoded.
#
# Generate one with:
#   pnpm --filter @statehub/web run gen:integration-key
#
# WARNING: losing this key makes existing encrypted tokens unrecoverable.
# You would have to re-enter tokens via the integrations form.
STATEHUB_INTEGRATION_KEY=

# E2E only — stubs provider REST/GraphQL calls so the test suite never
# hits real GitHub/Plane/Linear APIs. Production NEVER sets this.
# STATEHUB_E2E_FETCH_STUB=1
